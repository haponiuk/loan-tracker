{
    "type": "module",
    "scripts": {
        "dev": "vite --host 0.0.0.0 --port 5173",
        "dev:client": "vite --host 0.0.0.0 --port 5173",
        "dev:server": "node --watch server/index.js",
        "dev:local-api": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "db:start": "docker compose up -d postgres",
        "db:stop": "docker compose down",
        "db:migrate": "node scripts/migrate.js",
        "supabase:migrate": "node scripts/apply-supabase-schema.js",
        "supabase:migrate-bigint-ids": "node scripts/migrate-supabase-bigint-ids.js",
        "supabase:fix-identity-defaults": "node scripts/fix-supabase-identity-defaults.js",
        "supabase:seed": "node scripts/seed-supabase.js",
        "build": "vite build",
        "preview": "vite preview --host 0.0.0.0 --port 4173",
        "lint": "eslint api frontend server scripts"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.106.2",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "pg": "^8.21.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "vite": "^8.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^9.26.0",
        "autoprefixer": "^10.4.20",
        "css-loader": "^6.11.0",
        "eslint": "^9.26.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.0.0",
        "postcss": "^8.4.49",
        "postcss-loader": "^8.1.1",
        "style-loader": "^3.3.4",
        "tailwindcss": "^3.4.17"
    }
